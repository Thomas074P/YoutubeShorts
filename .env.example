# YouTube API Credentials
# Erhalte diese von: https://console.cloud.google.com/
YOUTUBE_CLIENT_ID=your_client_id_here
YOUTUBE_CLIENT_SECRET=your_client_secret_here

# OpenAI API Key (für DALL-E Bildgenerierung)
# Erhalte diesen von: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_key_here

# Weitere Optionen (optional)
# MUSIC_URL=https://example.com/royalty-free-music.mp3
# VIDEO_THEME=Jesus Christ as King
# VIDEO_TITLE=Your Custom Title
